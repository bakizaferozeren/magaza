{
    "name": "eticaret/cms",
    "description": "E-Ticaret CMS",
    "type": "project",
    "require": {
        "php": "^8.3",
        "vlucas/phpdotenv": "^5.6",
        "phpmailer/phpmailer": "^6.9",
        "intervention/image": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Helpers/functions.php",
            "app/Helpers/format.php",
            "app/Helpers/seo.php",
            "app/Helpers/schema.php"
        ]
    },
    "config": {
        "optimize-autoloader": true
    }
}
